{
  "name": "fcn-tracker",
  "version": "1.3.2",
  "description": "FCN 固定票息商品報價追蹤器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --win"
  },
  "build": {
    "appId": "com.jason4lin.fcn-tracker",
    "productName": "FCN Tracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!FCN2026.ods",
      "!dist/**",
      "!.github/**",
      "!*.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "jason4lin",
      "repo": "FCN-App"
    }
  },
  "keywords": [],
  "author": "FCN Tracker",
  "license": "ISC",
  "dependencies": {
    "electron-updater": "^6.8.3",
    "yahoo-finance2": "^3.14.0"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^25.1.8"
  }
}
